# ── Supabase ──────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your project values.
# Never commit .env.local to git.

# Your Supabase project URL (found in: Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon (public) key (found in: Settings → API)
# This key is safe to expose in the browser — RLS policies protect the data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── App ───────────────────────────────────────────────────────────────────────
# Base URL for the deployed app (used for PWA manifest)
NEXT_PUBLIC_APP_URL=https://thok.app
